# ST Character WeChat
# Copy to .env and fill only the values you need. Do not commit .env.

# User / WeChat allowlist.
# Character-only mode accepts one sender; if multiple IDs are listed, only the first is used.
ST_CHARACTER_WECHAT_USER_NAME=
ST_CHARACTER_WECHAT_USER_GENDER=female
ST_CHARACTER_WECHAT_ALLOWED_USER_IDS=
ST_CHARACTER_WECHAT_ACCOUNT_ID=
ST_CHARACTER_WECHAT_LOCAL_TIME_ZONE=Asia/Shanghai
ST_CHARACTER_WECHAT_LOCAL_LOCATION=

# Optional daily weather / outfit reminder.
# Requires an active character and a known WeChat context token; sends at most once per local day.
# When enabled, the app uses ST_CHARACTER_WECHAT_LOCAL_LOCATION to query public weather data.
ST_CHARACTER_WECHAT_DAILY_WEATHER_REMINDER_ENABLED=false
# The app chooses a random minute inside this local hour each day. If missed, it adds the reminder to the first reply that day.
ST_CHARACTER_WECHAT_DAILY_WEATHER_REMINDER_HOUR=8

# Local state and workspace
ST_CHARACTER_WECHAT_STATE_DIR=
ST_CHARACTER_WECHAT_WORKSPACE_ID=default
ST_CHARACTER_WECHAT_WORKSPACE_ROOT=

# Runtime: codex, claudecode, or api
ST_CHARACTER_WECHAT_RUNTIME=codex

# Remote OpenAI-compatible API runtime.
# Use ST_CHARACTER_WECHAT_RUNTIME=api for OpenAI, Gemini, DeepSeek, or another compatible provider.
# Base URL should usually be the provider's /v1 root unless the provider documents another OpenAI-compatible base URL.
# Examples: https://api.openai.com/v1, https://generativelanguage.googleapis.com/v1beta/openai, https://api.deepseek.com/v1
ST_CHARACTER_WECHAT_API_BASE_URL=
ST_CHARACTER_WECHAT_API_KEY=
ST_CHARACTER_WECHAT_API_MODEL=
ST_CHARACTER_WECHAT_API_HISTORY_LIMIT=80

# Local SillyTavern character cards.
# Default when empty: ./character-cards under this project root.
ST_CHARACTER_WECHAT_CHARACTER_CARD_DIR=

# Optional manual worldbook disable overrides exported by MANUAL_INSTRUCTION.html.
# Default when empty: ~/.st-character-wechat/characters/worldbook-overrides.json
ST_CHARACTER_WECHAT_CHARACTER_WORLDBOOK_OVERRIDES_FILE=

# Daily / weekly long-image report cards.
# Runtime returns JSON only; local HTML templates are rendered through Playwright to PNG.
ST_CHARACTER_WECHAT_USER_MEMORY_DIR=
ST_CHARACTER_WECHAT_USER_MEMORY_TIME_ZONE=Asia/Shanghai
ST_CHARACTER_WECHAT_USER_MEMORY_RECENT_DAYS=7
ST_CHARACTER_WECHAT_USER_MEMORY_UPCOMING_DAYS=21
ST_CHARACTER_WECHAT_AUTO_DAILY_REPORT_ENABLED=false
ST_CHARACTER_WECHAT_AUTO_DAILY_REPORT_TIME=23:30
ST_CHARACTER_WECHAT_AUTO_WEEKLY_REPORT_ENABLED=false
ST_CHARACTER_WECHAT_AUTO_WEEKLY_REPORT_WEEKDAY=monday
ST_CHARACTER_WECHAT_AUTO_WEEKLY_REPORT_TIME=23:30

# Optional long-term semantic memory retrieval.
# Leave disabled unless you want embedding/rerank recall beyond the default text date windows.
# Uses a separate API from the main chat runtime. Existing memory is not deleted; changing the embedding model rebuilds the local index.
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_ENABLED=false
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_BASE_URL=
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_API_KEY=
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_EMBEDDING_MODEL=
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_RERANK_ENABLED=false
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_RERANK_MODEL=
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_CANDIDATE_LIMIT=30
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_TOP_K=8
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_PASSIVE_MIN_SCORE=0.32
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_EXPLICIT_MIN_SCORE=0.12
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_RERANK_MIN_SCORE=0.05
ST_CHARACTER_WECHAT_MEMORY_RETRIEVAL_COOLDOWN_HOURS=24

ST_CHARACTER_WECHAT_REPORT_CARD_OUTPUT_DIR=
ST_CHARACTER_WECHAT_REPORT_CARD_TEMPLATE_DIR=
ST_CHARACTER_WECHAT_REPORT_CARD_WIDTH=720
ST_CHARACTER_WECHAT_REPORT_CARD_DEVICE_SCALE_FACTOR=2
ST_CHARACTER_WECHAT_REPORT_TIME_ZONE=Asia/Shanghai
ST_CHARACTER_WECHAT_PLAYWRIGHT_BROWSER_CHANNEL=msedge
ST_CHARACTER_WECHAT_PLAYWRIGHT_BROWSER_EXECUTABLE=

# WeChat bridge
ST_CHARACTER_WECHAT_WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
ST_CHARACTER_WECHAT_WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
ST_CHARACTER_WECHAT_WEIXIN_QR_BOT_TYPE=3
ST_CHARACTER_WECHAT_WEIXIN_MIN_CHUNK_CHARS=20

# Optional local services
ST_CHARACTER_WECHAT_ENABLE_LOCATION_SERVER=false
ST_CHARACTER_WECHAT_LOCATION_HOST=0.0.0.0
ST_CHARACTER_WECHAT_LOCATION_PORT=4318
ST_CHARACTER_WECHAT_LOCATION_TOKEN=
